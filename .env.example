# Copy to .env and fill in the keys you have. .env is gitignored.
# Every key is optional. The free layers (validate, surface, GitHub) run with none.

# GitHub: optional at depth 2, free. Raises the GitHub rate limit and reliability.
GITHUB_TOKEN=

# Tabstack: depth 3 company/web enrichment AND the cited, multi-source /research bio. A free account goes far.
TABSTACK_API_KEY=

# Hunter.io: depth 1 verify (0.5 credits/call) and depth 4 person enrichment (0.2 credits/call).
HUNTER_API_KEY=

# SixtyFour: depth 5 deep person + LinkedIn search. Async, takes minutes, premium. Only with --deep.
SIXTYFOUR_API_KEY=

# --- Headless / autonomous cost controls (optional) ---
# SixtyFour (--deep) will NOT run unless acceptance is present: this env opt-in, or an
# interactive confirmation. Set to 1 to grant standing acceptance for headless/agent use.
# DEV_TRACE_ALLOW_DEEP=1
# Default depth ceiling (0-4). The --max-depth flag overrides it. e.g. 2 = free layers only.
# DEV_TRACE_MAX_DEPTH=2
